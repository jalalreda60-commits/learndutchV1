{
  "cli": {
    "version": ">= 10.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "18.19.0",
      "android": {
        "image": "latest"
      }
    },

    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_APP_ENV": "development"
      },
      "cache": {
        "key": "dev-v1"
      }
    },

    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_APP_ENV": "preview"
      },
      "cache": {
        "key": "preview-v1"
      }
    },

    "production": {
      "extends": "base",
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_APP_ENV": "production"
      },
      "cache": {
        "key": "prod-v1"
      }
    },

    "production-apk": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },

  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "beta",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    }
  }
}
